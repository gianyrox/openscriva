# Encryption key for the scriva-keys httpOnly cookie.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_chars

# GitHub App for OAuth (create at https://github.com/settings/apps)
GITHUB_APP_ID=your_app_id
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_APP_SLUG=your-app-slug

# Server-side Anthropic key fallback (users supply their own in the UI)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# PostHog (optional — leave blank to disable analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
